# ===========================================
# ZULANTIQ Email Configuration
# ===========================================
# CRITICAL: Never commit this file to version control!
# Add .env to your .gitignore file

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS - Allowed domains (comma-separated)
# For development: http://localhost:4200 (Angular dev server)
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:4200,https://zulantiq.com,https://www.zulantiq.com

# ===========================================
# EMAIL CONFIGURATION - HOSTINGER SMTP
# ===========================================
# Get these from Hostinger Email Settings:
# cPanel > Email Accounts > Configure Email Client

# SMTP Server (usually mail.yourdomain.com)
SMTP_HOST=mail.zulantiq.com

# SMTP Port (465 for SSL, 587 for TLS)
SMTP_PORT=465

# Use SSL/TLS (true for port 465, false for 587)
SMTP_SECURE=true

# Your email account credentials
# IMPORTANT: Create a dedicated email like contacto@zulantiq.com
SMTP_USER=contacto@zulantiq.com
SMTP_PASS=YourStrongPasswordHere

# Sender name that appears in emails
EMAIL_FROM_NAME=ZULANTIQ Tech Consult

# Destination email (where form submissions go)
# Can be the same as SMTP_USER or different
EMAIL_TO=info@zulantiq.com

# Send automatic reply to client?
SEND_AUTO_REPLY=true

# ===========================================
# HOSTINGER SPECIFIC NOTES
# ===========================================
# 1. SMTP Host: Usually mail.yourdomain.com
# 2. Common Hostinger SMTP ports:
#    - Port 465 (SSL) - Recommended
#    - Port 587 (TLS)
#    - Port 25 (Non-SSL) - Not recommended
# 3. Authentication: Required (username + password)
# 4. Find settings in: Hostinger Panel > Emails > Email Accounts
