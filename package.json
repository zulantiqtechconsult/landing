{
  "name": "zulantiq-landing-backend",
  "version": "1.0.0",
  "description": "Node.js backend for ZULANTIQ Tech Consult contact form",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-email.js",
    "test:api": "node -e \"console.log('✅ Server configuration OK')\"",
    "setup": "npm install && echo '✅ Dependencies installed! Copy .env.example to .env and configure it.'",
